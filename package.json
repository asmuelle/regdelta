{
  "name": "regdelta",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @regdelta/web dev",
    "test": "vitest run",
    "eval": "vitest run eval",
    "e2e": "pnpm --filter @regdelta/web e2e",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "pnpm -r run typecheck",
    "build": "pnpm --filter @regdelta/web run build",
    "migrate": "pnpm --filter @regdelta/db run migrate"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@vitest/coverage-v8": "^3.2.0",
    "@types/node": "^22.15.0",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  }
}
